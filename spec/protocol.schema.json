{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pixel-protocol.dev/spec/protocol.schema.json",
  "title": "Pixel Protocol Schema",
  "type": "object",
  "required": [
    "meta",
    "packetComposition",
    "primitiveTypes",
    "compositeTypes",
    "packets"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["name", "version", "status"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "status": {"type": "string", "minLength": 1},
        "description": {"type": "string"},
        "repository": {"type": "string"}
      },
      "additionalProperties": true
    },
    "packetComposition": {
      "type": "object",
      "required": ["transport", "framing", "packet"],
      "properties": {
        "transport": {"type": "string", "minLength": 1},
        "framing": {
          "type": "object",
          "required": ["lengthPrefix", "encrypted"],
          "properties": {
            "lengthPrefix": {
              "type": "object",
              "required": ["name", "type", "endian"],
              "properties": {
                "name": {"type": "string"},
                "type": {"type": "string"},
                "endian": {"type": "string", "enum": ["big", "little"]},
                "includesSelf": {"type": "boolean"},
                "includesHeader": {"type": "boolean"},
                "includesPayload": {"type": "boolean"}
              },
              "additionalProperties": true
            },
            "encrypted": {"type": "boolean"}
          },
          "additionalProperties": true
        },
        "packet": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/typedElement"}
        },
        "notes": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "primitiveTypes": {
      "type": "array",
      "items": {"$ref": "#/$defs/typeDefinition"}
    },
    "compositeTypes": {
      "type": "array",
      "items": {"$ref": "#/$defs/typeDefinition"}
    },
    "packets": {
      "type": "object",
      "required": ["c2s", "s2c"],
      "properties": {
        "c2s": {
          "type": "array",
          "items": {"$ref": "#/$defs/packetDefinition"}
        },
        "s2c": {
          "type": "array",
          "items": {"$ref": "#/$defs/packetDefinition"}
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "typedElement": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "type": {"type": "string", "minLength": 1},
        "endian": {"type": "string", "enum": ["big", "little"]},
        "description": {"type": "string"}
      },
      "additionalProperties": true
    },
    "typeDefinition": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string"},
        "wireType": {"type": "string"}
      },
      "additionalProperties": true
    },
    "packetField": {
      "type": "object",
      "required": ["name", "type", "required"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "type": {"type": "string", "minLength": 1},
        "required": {"type": "boolean"},
        "description": {"type": "string"}
      },
      "additionalProperties": true
    },
    "packetDefinition": {
      "type": "object",
      "required": ["id", "name", "summary", "since", "fields"],
      "properties": {
        "id": {"type": "integer", "minimum": 0},
        "name": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "since": {"type": "string", "minLength": 1},
        "fields": {
          "type": "array",
          "items": {"$ref": "#/$defs/packetField"}
        }
      },
      "additionalProperties": true
    }
  }
}
